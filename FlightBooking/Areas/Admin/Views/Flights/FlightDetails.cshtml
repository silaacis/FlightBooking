@{
    ViewData["Title"] = "FlightDetails";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";
}

@* ============================================================
   Areas/Admin/Views/Flights/PassengerList.cshtml
   Model  : List<FlightBooking.Dtos.PassengerDtos.PassengerListItemDto>
   ViewBag: FlightNumber, AirlineCode, DepartureAirportCode,
            ArrivalAirportCode, DepartureTime, ArrivalTime,
            TotalSeats, OccupiedSeats, AvailableSeats, Status
   Layout : AdminLayout — SADECE CONTENT
============================================================ *@

@model List<FlightBooking.DTOs.PassengerDtos.PassengerListItemDto>

@{
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";
    ViewData["Title"] = "Uçuş Yolcu Listesi";

    @* Stat hesaplamaları *@
    int totalPassengers = Model?.Count ?? 0;

    int checkedIn = Model?.Count(p => p.CheckInStatus == "Checked-In") ?? 0;
    int paid = Model?.Count(p => p.PaymentStatus == "Paid") ?? 0;
    int issued = Model?.Count(p => p.TicketStatus == "Issued") ?? 0;
}

@section Styles {
    <style>

        .pl-page {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ── Flight Summary ───────────────────────────────────── */
        .flight-summary {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.06);
            padding: 24px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
        }

        .fs-left {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .fs-airline {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: #1a2e4a;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: .4px;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(26,46,74,.25);
        }

        .fs-codes {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.3px;
            line-height: 1;
        }

            .fs-codes .arr {
                font-size: 14px;
                color: #cbd5e1;
                font-weight: 400;
            }

        .fs-meta {
            font-size: 12.5px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .fs-divider {
            width: 1px;
            height: 48px;
            background: #f1f5f9;
            flex-shrink: 0;
        }

        .fs-stats {
            display: flex;
            align-items: center;
            gap: 28px;
            flex-wrap: wrap;
        }

        .fs-stat {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .fs-stat-val {
            font-size: 18px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1;
        }

        .fs-stat-lbl {
            font-size: 11px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .cap-bar-track {
            width: 120px;
            height: 6px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .cap-bar-fill {
            height: 100%;
            border-radius: 99px;
            background: linear-gradient(90deg,#f59e0b,#fbbf24);
        }

        .cap-nums {
            font-size: 11px;
            color: #64748b;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
        }

        /* ── Mini stat cards (check-in/ödeme/bilet) ───────────── */
        .mini-stats {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 12px;
        }

        .mini-stat {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 1px 3px rgba(15,23,42,.05);
        }

        .mini-stat-ico {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .mini-stat-val {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1;
        }

        .mini-stat-lbl {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 600;
            margin-top: 2px;
        }

        /* ── Filter ───────────────────────────────────────────── */
        .filter-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.06);
            padding: 18px 24px;
        }

        .filter-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #94a3b8;
            margin-bottom: 6px;
            display: block;
        }

        .filter-input {
            height: 36px;
            font-size: 13px;
            border-color: #e2e8f0;
            border-radius: 8px;
            color: #1e293b;
            transition: border-color .15s, box-shadow .15s;
        }

            .filter-input:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59,130,246,.12);
            }

        /* ── Table Card ───────────────────────────────────────── */
        .table-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.06);
            overflow: hidden;
        }

        .table-card-header {
            padding: 16px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }

        /* ── Pax Table ────────────────────────────────────────── */
        .pax-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

            .pax-table thead th {
                padding: 10px 14px;
                font-size: 10.5px;
                font-weight: 700;
                letter-spacing: .7px;
                text-transform: uppercase;
                color: #94a3b8;
                background: #f8fafc;
                border-bottom: 1px solid #f1f5f9;
                white-space: nowrap;
            }

            .pax-table tbody tr {
                transition: background .12s;
            }

                .pax-table tbody tr:hover {
                    background: #f8fafc;
                }

                    .pax-table tbody tr:hover td:first-child {
                        border-left-color: #3b82f6;
                    }

            .pax-table tbody td {
                padding: 13px 14px;
                vertical-align: middle;
                font-size: 13.5px;
                border-bottom: 1px solid #f1f5f9;
                border-left: 3px solid transparent;
                transition: border-color .12s;
            }

            .pax-table tbody tr:last-child td {
                border-bottom: none;
            }

        /* Avatar */
        .pax-avatar {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            flex-shrink: 0;
            letter-spacing: .3px;
        }

        .pax-name-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pax-name {
            font-weight: 600;
            font-size: 13.5px;
            color: #0f172a;
            white-space: nowrap;
        }

        .pax-email {
            font-size: 11px;
            color: #94a3b8;
        }

        /* Badges */
        .bp {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 600;
            white-space: nowrap;
        }

            .bp .dot {
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: currentColor;
                flex-shrink: 0;
            }

        .bp-green {
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .bp-gray {
            background: #f8fafc;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

        .bp-yellow {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .bp-red {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .bp-blue {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        /* Seat */
        .seat-badge {
            display: inline-block;
            padding: 3px 9px;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 700;
            background: #f1f5f9;
            color: #475569;
            font-variant-numeric: tabular-nums;
            letter-spacing: .3px;
        }

        /* Action buttons */
        .act-wrap {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .aib {
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 7px;
            font-size: 13px;
            cursor: pointer;
            transition: all .14s;
            text-decoration: none;
            border: 1px solid transparent;
        }

        .aib-view {
            background: #eff6ff;
            color: #2563eb;
            border-color: #dbeafe;
        }

            .aib-view:hover {
                background: #dbeafe;
            }

        .aib-edit {
            background: #fffbeb;
            color: #d97706;
            border-color: #fef3c7;
        }

            .aib-edit:hover {
                background: #fef3c7;
            }

        .aib-del {
            background: #fef2f2;
            color: #dc2626;
            border-color: #fecaca;
        }

            .aib-del:hover {
                background: #fecaca;
            }

        /* Pagination */
        .pag-wrap {
            padding: 14px 20px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            background: #fafbfc;
        }

        .pag-info {
            font-size: 12.5px;
            color: #94a3b8;
            font-weight: 500;
        }

        .pag-list {
            display: flex;
            gap: 3px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

            .pag-list li a,
            .pag-list li span {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 32px;
                height: 32px;
                border-radius: 8px;
                font-size: 12.5px;
                font-weight: 500;
                border: 1px solid #e2e8f0;
                background: #fff;
                color: #64748b;
                text-decoration: none;
                transition: all .14s;
                cursor: pointer;
            }

                .pag-list li a:hover {
                    background: #eff6ff;
                    border-color: #bfdbfe;
                    color: #2563eb;
                }

            .pag-list li.active a {
                background: #2563eb;
                border-color: #2563eb;
                color: #fff;
                font-weight: 700;
                box-shadow: 0 2px 8px rgba(37,99,235,.3);
            }

            .pag-list li.disabled span {
                opacity: .35;
                cursor: not-allowed;
            }

        /* Empty state */
        .empty-state {
            padding: 56px 24px;
            text-align: center;
            color: #94a3b8;
        }

            .empty-state i {
                font-size: 38px;
                display: block;
                margin-bottom: 10px;
                opacity: .2;
            }

        @@media (max-width:1100px) {
            .fs-divider {
                display: none;
            }

            .mini-stats {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width:768px) {
            .flight-summary {
                flex-direction: column;
                align-items: flex-start;
            }

            .mini-stats {
                grid-template-columns: 1fr;
            }
        }

    </style>
}

<main class="main-content" id="main-content">
    <div class="container-fluid px-4 py-4">
        <div class="pl-page">

            @* ── Başlık ── *@
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size:12.5px;">
                            <li class="breadcrumb-item">
                                <a href="#" class="text-decoration-none text-muted">Dashboard</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a asp-area="Admin" asp-controller="Flights" asp-action="Index"
                                   class="text-decoration-none text-muted">Uçuşlar</a>
                            </li>
                            <li class="breadcrumb-item active">Yolcu Listesi</li>
                        </ol>
                    </nav>
                    <h4 class="fw-bold mb-1" style="color:#0f172a;">Uçuş Yolcu Listesi</h4>
                    <p class="text-muted mb-0" style="font-size:13px;">
                        Seçilen uçuşa ait tüm yolcuları görüntüleyin ve yönetin.
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-area="Admin" asp-controller="Flights" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm px-3"
                       style="border-radius:8px;font-size:13px;">
                        <i class="bi bi-arrow-left me-1"></i> Geri
                    </a>
                </div>
            </div>

            @* ── Flight Summary Card (ViewBag ile statik) ── *@
            <div class="flight-summary">
                <div class="fs-left">
                    <div class="fs-airline">@ViewBag.AirlineCode</div>

                    <div>
                        <div class="fs-codes">
                            @ViewBag.DepartureAirportCode
                            <span class="arr"><i class="bi bi-arrow-right"></i></span>
                            @ViewBag.ArrivalAirportCode
                        </div>
                        <div class="fs-meta mt-1">
                            <span><i class="bi bi-hash" style="font-size:11px;"></i> @ViewBag.FlightNumber</span>
                            <span style="color:#e2e8f0;">·</span>
                            <span>
                                <i class="bi bi-calendar3" style="font-size:11px;"></i>
                                @(((DateTime)ViewBag.DepartureTime).ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
                            </span>
                            <span style="color:#e2e8f0;">·</span>
                            <span>
                                <i class="bi bi-clock" style="font-size:11px;"></i>
                                @(((DateTime)ViewBag.DepartureTime).ToString("HH:mm")) →
                                @(((DateTime)ViewBag.ArrivalTime).ToString("HH:mm"))
                            </span>
                        </div>
                    </div>

                    <div class="fs-divider"></div>

                    <div class="fs-stats">
                        <div class="fs-stat">
                            <span class="fs-stat-val">@totalPassengers</span>
                            <span class="fs-stat-lbl">Yolcu</span>
                        </div>
                        <div class="fs-stat">
                            <span class="fs-stat-val">@ViewBag.TotalSeats</span>
                            <span class="fs-stat-lbl">Kapasite</span>
                        </div>

                        @{
                            int totalSeats = (int)(ViewBag.TotalSeats ?? 1);
                            int occRate = totalSeats > 0
                            ? (int)Math.Round((double)totalPassengers / totalSeats * 100)
                            : 0;
                            string barColor = occRate >= 85
                            ? "background:linear-gradient(90deg,#ef4444,#f87171)"
                            : occRate >= 60
                            ? "background:linear-gradient(90deg,#f59e0b,#fbbf24)"
                            : "background:linear-gradient(90deg,#22c55e,#4ade80)";
                        }

                        <div>
                            <div class="cap-bar-track">
                                <div class="cap-bar-fill" style="width:@occRate%;@barColor"></div>
                            </div>
                            <div class="cap-nums mt-1">
                                <span style="font-weight:700;color:@(occRate >= 85 ? "#dc2626" : occRate >= 60 ? "#d97706" : "#16a34a")">
                                    %@occRate Dolu
                                </span>
                                <span>@(totalSeats - totalPassengers) boş</span>
                            </div>
                        </div>

                        <div class="fs-stat">
                            <span class="bp bp-blue" style="font-size:12px;">
                                <i class="bi bi-circle-fill" style="font-size:7px;"></i>
                                @ViewBag.Status
                            </span>
                            <span class="fs-stat-lbl mt-1">Durum</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-primary btn-sm px-3"
                            style="border-radius:8px;font-size:13px;font-weight:600;">
                        <i class="bi bi-grid-3x3-gap me-1"></i> Seat Map
                    </button>
                    <button class="btn btn-sm px-3 fw-semibold"
                            style="border-radius:8px;font-size:13px;background:#16a34a;color:#fff;border-color:#16a34a;">
                        <i class="bi bi-file-earmark-excel me-1"></i> Excel İndir
                    </button>
                </div>
            </div>

            @* ── Mini İstatistik Kartları (model'den dinamik) ── *@
            <div class="mini-stats">
                <div class="mini-stat">
                    <div class="mini-stat-ico" style="background:#f0fdf4;color:#16a34a;">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                    <div>
                        <div class="mini-stat-val">@checkedIn / @totalPassengers</div>
                        <div class="mini-stat-lbl">Check-in Yapıldı</div>
                    </div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat-ico" style="background:#eff6ff;color:#2563eb;">
                        <i class="bi bi-credit-card-fill"></i>
                    </div>
                    <div>
                        <div class="mini-stat-val">@paid / @totalPassengers</div>
                        <div class="mini-stat-lbl">Ödeme Tamamlandı</div>
                    </div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat-ico" style="background:#f5f3ff;color:#7c3aed;">
                        <i class="bi bi-ticket-perforated-fill"></i>
                    </div>
                    <div>
                        <div class="mini-stat-val">@issued / @totalPassengers</div>
                        <div class="mini-stat-lbl">Bilet Kesildi</div>
                    </div>
                </div>
            </div>

            @* ── Filtre ── *@
            <div class="filter-card">
                <div class="row g-3 align-items-end">

                    <div class="col-12 col-md-2">
                        <label class="filter-label">Ad Soyad</label>
                        <input type="text" id="fName" class="form-control filter-input"
                               placeholder="Yolcu adı…" oninput="applyFilter()" />
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="filter-label">PNR</label>
                        <input type="text" id="fPnr" class="form-control filter-input"
                               placeholder="ABC123" oninput="applyFilter()" />
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="filter-label">Check-in Durumu</label>
                        <select id="fCheckin" class="form-select filter-input" onchange="applyFilter()">
                            <option value="">Tümü</option>
                            <option value="Checked-In">Check-in Yapıldı</option>
                            <option value="Not Checked">Yapılmadı</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="filter-label">Ödeme Durumu</label>
                        <select id="fPayment" class="form-select filter-input" onchange="applyFilter()">
                            <option value="">Tümü</option>
                            <option value="Paid">Ödendi</option>
                            <option value="Pending">Beklemede</option>
                            <option value="Failed">Başarısız</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="filter-label">Yolcu Tipi</label>
                        <select id="fType" class="form-select filter-input" onchange="applyFilter()">
                            <option value="">Tümü</option>
                            <option value="Yetişkin">Yetişkin</option>
                            <option value="Çocuk">Çocuk</option>
                            <option value="Bebek">Bebek</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-2 d-flex gap-2">
                        <button class="btn btn-primary btn-sm flex-fill fw-semibold"
                                onclick="applyFilter()"
                                style="border-radius:8px;height:36px;">
                            <i class="bi bi-funnel-fill me-1"></i> Filtrele
                        </button>
                        <button class="btn btn-outline-secondary btn-sm"
                                onclick="clearFilter()"
                                style="border-radius:8px;height:36px;width:36px;padding:0;"
                                title="Temizle">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                </div>
            </div>

            @* ── Table Card ── *@
            <div class="table-card">

                <div class="table-card-header">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-semibold" style="font-size:13.5px;color:#0f172a;">Yolcu Listesi</span>
                        <span class="bp bp-blue" id="totalBadge"
                              style="font-size:11.5px;padding:4px 10px;">
                            @totalPassengers yolcu
                        </span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary btn-sm"
                                style="border-radius:8px;font-size:12.5px;">
                            <i class="bi bi-arrow-up-down me-1"></i> Sırala
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="pax-table" id="paxTable">
                        <thead>
                            <tr>
                                <th>YOLCU</th>
                                <th>CİNSİYET</th>
                                <th>TİP</th>
                                <th>PNR</th>
                                <th>KOLTUK</th>
                                <th>CHECK-IN</th>
                                <th>ÖDEME</th>
                                <th>BİLET</th>
                                <th>İLETİŞİM</th>
                                <th>İŞLEMLER</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            @* JS tarafından render edilir *@
                        </tbody>
                    </table>
                </div>

                <div class="pag-wrap">
                    <span class="pag-info" id="pageInfo"></span>
                    <ul class="pag-list" id="pagination"></ul>
                </div>

            </div>

        </div>
    </div>
</main>
</main>

@section Scripts {
    <script>

        var allPassengers = [
            @if (Model != null && Model.Any())
            {
                    foreach (var p in Model)
                    {
                            @:{ name: "@p.Name", surname: "@p.Surname",
                            @:  email: "@(p.Email ?? "")", phone: "@(p.Phone ?? "")",
                            @:  gender: "@(p.Gender ?? "")",
                            @:  type: "@(p.PassengerType ?? "")",
                            @:  pnr: "@(p.Pnr ?? "")",
                            @:  seat: "@(p.SeatNumber ?? "—")",
                            @:  checkin: "@(p.CheckInStatus ?? "Not Checked")",
                            @:  payment: "@(p.PaymentStatus ?? "Pending")",
                            @:  ticket: "@(p.TicketStatus ?? "Not Issued")" },
                    }
            }
        ];

        var filtered    = allPassengers.slice();
        var currentPage = 1;
        var perPage     = 8;

        /* ── Avatar renkleri ─────────────────────────────────── */
        var avatarColors = [
            '#1a2e4a','#065f46','#7c2d12','#1e40af',
            '#6b21a8','#991b1b','#0e7490','#a16207',
            '#064e3b','#1e3a5f','#4a044e','#7f1d1d'
        ];

        function getColor(name) {
            var i = 0;
            for (var c = 0; c < name.length; c++) i += name.charCodeAt(c);
            return avatarColors[i % avatarColors.length];
        }

        function initials(name, surname) {
            return ((name[0] || '') + (surname[0] || '')).toUpperCase();
        }

        /* ── Badge helpers ───────────────────────────────────── */
        function checkinBadge(v) {
            return v === 'Checked-In'
                ? '<span class="bp bp-green"><span class="dot"></span>Yapıldı</span>'
                : '<span class="bp bp-gray"><span class="dot"></span>Yapılmadı</span>';
        }

        function paymentBadge(v) {
            if (v === 'Paid')    return '<span class="bp bp-green"><span class="dot"></span>Ödendi</span>';
            if (v === 'Pending') return '<span class="bp bp-yellow"><span class="dot"></span>Beklemede</span>';
            if (v === 'Failed')  return '<span class="bp bp-red"><span class="dot"></span>Başarısız</span>';
            return '<span class="bp bp-gray"><span class="dot"></span>' + (v || '—') + '</span>';
        }

        function ticketBadge(v) {
            return v === 'Issued'
                ? '<span class="bp bp-blue"><span class="dot"></span>Kesildi</span>'
                : '<span class="bp bp-gray"><span class="dot"></span>Kesilmedi</span>';
        }

        function typeBadge(v) {
            var cls = v === 'Yetişkin' ? 'bp-blue' : v === 'Çocuk' ? 'bp-yellow' : 'bp-gray';
            return '<span class="bp ' + cls + '">' + (v || '—') + '</span>';
        }

        /* ── Filter ──────────────────────────────────────────── */
        function applyFilter() {
            var name    = (document.getElementById('fName').value    || '').toLowerCase().trim();
            var pnr     = (document.getElementById('fPnr').value     || '').toLowerCase().trim();
            var checkin =  document.getElementById('fCheckin').value;
            var payment =  document.getElementById('fPayment').value;
            var type    =  document.getElementById('fType').value;

            filtered = allPassengers.filter(function(p) {
                var fullName = (p.name + ' ' + p.surname).toLowerCase();
                return (!name    || fullName.includes(name))
                    && (!pnr     || (p.pnr || '').toLowerCase().includes(pnr))
                    && (!checkin || p.checkin === checkin)
                    && (!payment || p.payment === payment)
                    && (!type    || p.type    === type);
            });

            currentPage = 1;
            render();
        }

        function clearFilter() {
            document.getElementById('fName').value    = '';
            document.getElementById('fPnr').value     = '';
            document.getElementById('fCheckin').value = '';
            document.getElementById('fPayment').value = '';
            document.getElementById('fType').value    = '';
            filtered = allPassengers.slice();
            currentPage = 1;
            render();
        }

        /* ── Render ──────────────────────────────────────────── */
        function render() {
            var total      = filtered.length;
            var totalPages = Math.max(1, Math.ceil(total / perPage));
            if (currentPage > totalPages) currentPage = totalPages;

            var from  = total === 0 ? 0 : (currentPage - 1) * perPage + 1;
            var to    = Math.min(currentPage * perPage, total);
            var slice = filtered.slice(from - 1, to);

            document.getElementById('totalBadge').textContent = total + ' yolcu';
            document.getElementById('pageInfo').textContent   = total === 0
                ? 'Sonuç bulunamadı'
                : 'Showing ' + from + ' to ' + to + ' of ' + total + ' entries';

            var tbody = document.getElementById('tableBody');

            if (slice.length === 0) {
                tbody.innerHTML =
                    '<tr><td colspan="10" class="text-center py-5 text-muted">' +
                        '<i class="bi bi-person-slash" style="font-size:36px;display:block;margin-bottom:10px;opacity:.2;"></i>' +
                        'Yolcu bulunamadı.' +
                    '</td></tr>';
                document.getElementById('pagination').innerHTML = '';
                return;
            }

            tbody.innerHTML = slice.map(function(p) {
                var color = getColor(p.name);
                var init  = initials(p.name, p.surname);

                return '<tr>' +

                    /* Yolcu */
                    '<td>' +
                        '<div class="pax-name-cell">' +
                            '<div class="pax-avatar" style="background:' + color + '1a;color:' + color + ';">' + init + '</div>' +
                            '<div>' +
                                '<div class="pax-name">' + p.name + ' ' + p.surname + '</div>' +
                                '<div class="pax-email">' + (p.email || '') + '</div>' +
                            '</div>' +
                        '</div>' +
                    '</td>' +

                    /* Cinsiyet */
                    '<td><span style="font-size:13px;color:#475569;">' +
                        '<i class="bi bi-' + (p.gender === 'Erkek' ? 'gender-male text-primary' : p.gender === 'Kadın' ? 'gender-female text-danger' : 'dash') + ' me-1"></i>' +
                        (p.gender || '—') +
                    '</span></td>' +

                    /* Tip */
                    '<td>' + typeBadge(p.type) + '</td>' +

                    /* PNR */
                    '<td><span style="font-family:monospace;font-weight:700;font-size:12.5px;color:#0f172a;background:#f8fafc;padding:3px 8px;border-radius:6px;border:1px solid #f1f5f9;">' +
                        (p.pnr || '—') +
                    '</span></td>' +

                    /* Koltuk */
                    '<td><span class="seat-badge">' + (p.seat || '—') + '</span></td>' +

                    /* Check-in */
                    '<td>' + checkinBadge(p.checkin) + '</td>' +

                    /* Ödeme */
                    '<td>' + paymentBadge(p.payment) + '</td>' +

                    /* Bilet */
                    '<td>' + ticketBadge(p.ticket) + '</td>' +

                    /* İletişim */
                    '<td><span style="font-size:12.5px;color:#64748b;white-space:nowrap;">' +
                        (p.phone ? '<i class="bi bi-telephone me-1" style="font-size:11px;"></i>' + p.phone : '—') +
                    '</span></td>' +

                    /* İşlemler */
                    '<td>' +
                        '<div class="act-wrap">' +
                            '<a href="#" class="aib aib-view" title="Detay"><i class="bi bi-eye-fill"></i></a>' +
                            '<a href="#" class="aib aib-edit" title="Düzenle"><i class="bi bi-pencil-fill"></i></a>' +
                            '<button class="aib aib-del" title="İptal" style="border:none;cursor:pointer;"><i class="bi bi-trash-fill"></i></button>' +
                        '</div>' +
                    '</td>' +

                '</tr>';
            }).join('');

            renderPagination(totalPages);
        }

        /* ── Pagination ──────────────────────────────────────── */
        function renderPagination(totalPages) {
            var ul   = document.getElementById('pagination');
            var html = '';

            html += '<li class="' + (currentPage === 1 ? 'disabled' : '') + '">' +
                '<span onclick="' + (currentPage > 1 ? 'goPage(currentPage-1)' : '') + '"' +
                ' style="cursor:' + (currentPage === 1 ? 'default' : 'pointer') + '">' +
                '<i class="bi bi-chevron-left" style="font-size:10px;"></i></span></li>';

            buildRange(currentPage, totalPages).forEach(function(p) {
                if (p === '...') {
                    html += '<li><span style="cursor:default;border:none;background:none;color:#94a3b8;">…</span></li>';
                } else {
                    html += '<li class="' + (p === currentPage ? 'active' : '') + '">' +
                        '<a onclick="goPage(' + p + ')">' + p + '</a></li>';
                }
            });

            html += '<li class="' + (currentPage === totalPages ? 'disabled' : '') + '">' +
                '<span onclick="' + (currentPage < totalPages ? 'goPage(currentPage+1)' : '') + '"' +
                ' style="cursor:' + (currentPage === totalPages ? 'default' : 'pointer') + '">' +
                '<i class="bi bi-chevron-right" style="font-size:10px;"></i></span></li>';

            ul.innerHTML = html;
        }

        function buildRange(cur, total) {
            if (total <= 7) {
                var a = [];
                for (var i = 1; i <= total; i++) a.push(i);
                return a;
            }
            var pages = [1];
            if (cur > 3) pages.push('...');
            for (var x = Math.max(2, cur-1); x <= Math.min(total-1, cur+1); x++) pages.push(x);
            if (cur < total-2) pages.push('...');
            pages.push(total);
            return pages;
        }

        function goPage(p) {
            var total = Math.max(1, Math.ceil(filtered.length / perPage));
            if (p < 1 || p > total) return;
            currentPage = p;
            render();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        document.addEventListener('DOMContentLoaded', function() { render(); });

    </script>
}
